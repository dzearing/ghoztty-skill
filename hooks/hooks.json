{
  "description": "Ghoztty status banner — keep a per-pane sticky banner (title, goal, status, what you asked / did, PR link) current across the session.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/scripts && ln -sf \"${CLAUDE_PLUGIN_ROOT}/hooks/ghoztty-banner.sh\" ~/.claude/scripts/ghoztty-banner.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ghoztty-banner.sh\" prompt-hook",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ghoztty-banner.sh\" stop-hook",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ghoztty-banner.sh\" posttool-hook",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
